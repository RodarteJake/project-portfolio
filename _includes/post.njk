<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} - Jake Rodarte</title>
    <link rel="stylesheet" href="../../styles.css">
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@500;700&family=IBM+Plex+Sans:wght@400;500&display=swap" rel="stylesheet">
</head>
<body>
    <header class="navbar">
        <div class="nav-container container">
            <a href="../../index.html" class="nav-logo">Jake Rodarte</a>
            <nav>
                <ul class="nav-menu">
                    <li class="nav-item"><a class="nav-link" href="../../index.html">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="../../index.html#about">About</a></li>
                    <li class="nav-item"><a class="nav-link" href="../../index.html#projects">Projects</a></li>
                    <li class="nav-item"><a class="nav-link" href="../../blog/">Blog</a></li>
                    <li class="nav-item"><a class="nav-link" href="../../index.html#contact">Contact</a></li>
                </ul>
            </nav>
            <button class="hamburger" aria-label="Toggle navigation menu" type="button">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </div>
    </header>

    <section class="post-content">
        <div class="container post-container">
            <article id="post" class="blog-post">
                <div class="post-header">
                    <h1>{{ title }}</h1>
                    <div class="post-meta">
                        <span class="post-date">{{ date | dateFilter }}</span>
                        {% if author %}<span class="post-author">by {{ author }}</span>{% endif %}
                    </div>
                </div>
                <div class="post-body">
                    {{ content | safe }}
                </div>
            </article>
            <aside class="post-sidebar">
                <a href="../../blog/" class="back-to-blog">← Back to Blog</a>
            </aside>
        </div>
    </section>

    <footer class="footer">
        <div class="footer-content container">
            <p>Made with HTML, CSS, and JavaScript.</p>
            <div class="social-links">
                <a class="social-link" href="https://github.com/RodarteJake">GitHub</a>
                <a class="social-link" href="https://www.linkedin.com/in/jacob-rodarte-a1a435407/">LinkedIn</a>
            </div>
        </div>
    </footer>

    <script type="module" src="../../scripts/main.js"></script>
</body>
</html>
